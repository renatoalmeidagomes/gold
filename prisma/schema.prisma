datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Float
  imageUrl    String
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id   String @id @default(cuid())
  name String
}

model Config {
  id              String  @id @default("main")
  storeName       String  @default("Black Gold")
  primaryColor    String  @default("#000000")
  logoUrl         String?
  whatsapp        String  @default("")
  instagram       String  @default("")
  pixKey          String  @default("")
  pixReceiverName String  @default("")
}