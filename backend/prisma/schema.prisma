datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float
  category    String
  images      String[]
  sizes       String[]
  colors      String[]
  badge       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id   String @id @default(cuid())
  name String
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  username  String?  @unique
  phone     String
  address   String
  password  String
  role      UserRole @default(CLIENTE)
  isActive  Boolean  @default(true)
  orders    Order[]
  createdAt DateTime @default(now())
}

enum UserRole {
  CLIENTE
  ADMIN
}

model Order {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  items          Json
  subtotal       Float
  shipping       Float
  total          Float
  status         String   @default("Pendente")
  pickup         Boolean  @default(false)
  paymentDetails Json?
  couponApplied  String?
  createdAt      DateTime @default(now())
}

model Config {
  id              String  @id @default("main")
  storeName       String  @default("Ecommerce")
  primaryColor    String  @default("#000000")
  logo            String  @default("")
  whatsapp        String  @default("")
  instagram       String  @default("")
  addressLine1    String  @default("")
  addressLine2    String  @default("")
  addressLine3    String  @default("")
  pixKey          String  @default("")
  pixReceiverName String  @default("")
  pixCity         String  @default("ALMENARA")
  shippingFee     Float   @default(0.0)
}
